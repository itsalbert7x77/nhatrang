{{ $pages := where .Site.RegularPages "Type" "!=" "page" }}
[{{ range $i, $p := $pages }}{{ if $i }},{{ end }}
{
  "title": {{ .Title | jsonify }},
  "url": {{ .Permalink | jsonify }},
  "description": {{ with .Description }}{{ . | jsonify }}{{ else }}""{{ end }},
  "section": {{ .Section | jsonify }},
  "date": {{ .Date.Format "2006-01-02" | jsonify }},
  "tags": {{ with .Params.tags }}{{ . | jsonify }}{{ else }}[]{{ end }},
  "content": {{ .Plain | truncate 300 | jsonify }}
}{{ end }}
]
